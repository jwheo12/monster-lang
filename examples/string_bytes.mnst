import "std/mem.mnst";
import "std/str.mnst";

fn main() -> i32 {
    let src: str = "Monster";
    let len = str_len(src);
    let buf = mem_calloc_u8(len + (1 as usize));
    defer mem_free_u8(buf);

    str_copy_to(buf, src);

    if str_equals(src, buf as str) {
        print_ln_str(buf as str);
    }

    print_ln_i32(mem_cmp(buf, src as *u8, len));

    return len as i32;
}
